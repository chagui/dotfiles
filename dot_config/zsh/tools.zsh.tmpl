# asdf
export ASDF_CONFIG_FILE="$XDG_CONFIG_HOME/asdf/config"
export ASDF_DATA_DIR="$XDG_DATA_HOME/asdf"
{{- if eq .chezmoi.os "darwin" }}
asdf_source="{{ output "brew" "--prefix" "asdf" | trim }}/libexec/asdf.sh"
{{  else if eq .chezmoi.os "linux" }}
{{- if eq .chezmoi.osRelease.id "ubuntu" }}
asdf_source="$HOME/.asdf/asdf.sh"
{{ end -}}
{{ end }}
if [ -s "$asdf_source" ]; then
    source "$asdf_source"
fi
fpath=(${ASDF_DIR}/completions $fpath)

# delta
if command -v delta &>/dev/null; then
    compdef _gnu_generic delta
fi

# graphite
_gt_cache="$XDG_CACHE_HOME/zsh/gt-completion.zsh"
if [[ ! -s "$_gt_cache" ]] && command -v gt &>/dev/null; then
    mkdir -p "${_gt_cache:h}"
    gt completion > "$_gt_cache"
fi
[ -s "$_gt_cache" ] && source "$_gt_cache"

{{- if eq .chezmoi.os "darwin" }}
# homebrew
# Force certain more-secure behaviours from homebrew
export HOMEBREW_NO_INSECURE_REDIRECT=1
export HOMEBREW_CASK_OPTS=--require-sha
{{- end }}

# kubectl
if command -v kubectl &>/dev/null; then
    alias k='kubectl'
    alias kd='kubectl describe'
    alias ke='kubectl edit'
    alias kg='kubectl get'
    alias kl='kubectl logs'
    alias kx='kubectl exec -it'
    export KUBECACHEDIR="$XDG_CACHE_HOME/kube"
    export KUBECONFIG="$XDG_CONFIG_HOME/kube/config"
fi

# k9s
if command -v k9s &>/dev/null; then
    alias k9s='EDITOR=nvim k9s'
fi

# less
export LESSHISTFILE="$XDG_STATE_HOME/less/history"
export LESSKEY="$XDG_STATE_HOME/less/keys"

# mypy
export MYPY_CACHE_DIR="$XDG_CACHE_HOME/mypy"

# op — cache completions to avoid running `op` on every shell init
# (op accesses 1Password app data, which triggers macOS privacy prompts)
if command -v op &>/dev/null; then
    _op_comp_cache="${XDG_CACHE_HOME:-$HOME/.cache}/zsh/op_completion.zsh"
    if [[ ! -f "$_op_comp_cache" || "$(op --version 2>/dev/null)" != "$(head -1 "$_op_comp_cache" 2>/dev/null | sed 's/^# //')" ]]; then
        mkdir -p "${_op_comp_cache:h}"
        { echo "# $(op --version 2>/dev/null)"; op completion zsh; } > "$_op_comp_cache"
    fi
    source "$_op_comp_cache"
    compdef _op op
fi

# psql
export PSQLRC="$XDG_CONFIG_HOME/psql/psqlrc"
export PGPASSFILE="$XDG_CONFIG_HOME/pg/pgpass"
export PGSERVICEFILE="$XDG_CONFIG_HOME/pg/pg_service.conf"
export PSQL_HISTORY="$XDG_STATE_HOME/psql/history"

# redis-cli
export REDISCLI_RCFILE="$XDG_CONFIG_HOME/rediscli/config"
export REDISCLI_HISTFILE="$XDG_STATE_HOME/rediscli/history"

# ripgrep
export RIPGREP_CONFIG_PATH="$XDG_CONFIG_HOME/ripgrep/config"

# terraform
export TF_CLI_CONFIG_FILE="$XDG_CONFIG_HOME/terraform/config"
alias tf='terraform'

# nvim
alias v='nvim'

# wget
export WGETRC="$XDG_CONFIG_HOME/wget/wgetrc"

# zoxide
_zoxide_cache="$XDG_CACHE_HOME/zsh/zoxide-init.zsh"
if [[ ! -s "$_zoxide_cache" ]] && command -v zoxide &>/dev/null; then
    mkdir -p "${_zoxide_cache:h}"
    zoxide init --cmd cd zsh > "$_zoxide_cache"
fi
[ -s "$_zoxide_cache" ] && source "$_zoxide_cache"

# Re-assert Yarn Switch + Volta PATH ordering. dot_zshenv already puts them
# ahead of system PATH for non-interactive shells, but in interactive shells
# `eval $(brew shellenv)` in dot_zshrc.tmpl prepends /opt/homebrew/bin, which
# slots /opt/homebrew/bin/node ahead of Volta's shim. tools.zsh is sourced as
# the last line of .zshrc, so re-prepending here survives startup.
if [[ -n ${VOLTA_HOME-} ]]; then
    export PATH="$VOLTA_HOME/bin:$PATH"
fi
if [[ -s $HOME/.yarn/switch/env ]]; then
    source "$HOME/.yarn/switch/env"
fi
