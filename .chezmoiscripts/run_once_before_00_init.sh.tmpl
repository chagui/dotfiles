#!/bin/bash
set -eufo pipefail

mkdir -p "$XDG_DATA_HOME/zsh/completions"

# shellcheck disable=1054,1083
{{- if eq .chezmoi.os "darwin" }}
# Install Homebrew if not already installed
if ! command -v brew &> /dev/null; then
    echo "🍺  Installing Homebrew"
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
    eval "$(/opt/homebrew/bin/brew shellenv)"
fi

# Install packages from embedded Brewfile
echo "Installing packages from Brewfile..."
brew bundle --file=/dev/stdin <<EOF
tap "1password/tap"
tap "cirruslabs/cli"
tap "derailed/k9s"
tap "hashicorp/tap"
tap "romkatv/powerlevel10k"
tap "terraform-docs/tap"
tap "withered-magic/brew"
tap "withgraphite/tap"
brew "openssl@3"
brew "readline"
brew "sqlite"
brew "xz"
brew "ansible"
brew "ansible-lint"
brew "lz4"
brew "zstd"
brew "git"
brew "aws-vault"
brew "awscli"
brew "bash"
brew "bat"
brew "cargo-binstall"
brew "bazelisk"
brew "broot"
brew "buf"
brew "buildifier"
brew "buildozer"
brew "cdk8s"
brew "chezmoi"
brew "cmake"
brew "coreutils"
brew "crane"
brew "curl"
brew "dive"
brew "dog"
brew "dust"
brew "eza"
brew "fd"
